{
  "name": "@uigraph/sdk",
  "version": "1.0.8",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "test": "vitest --run",
    "lint": "eslint .",
    "fix": "eslint . --fix",
    "tsc": "tsc --noEmit",
    "tc": "tsc --noEmit --watch",
    "exports": "tsx ./write-exports.ts",
    "build": "tsdown --config ./tsdown.config.ts",
    "dev": "concurrently --names \"R,T,V\" --prefix-colors \"blue.dim,magenta.dim,green.dim\" \"tsdown --config ./tsdown.config.ts --watch\" \"tsc --noEmit --watch\" \"vitest dev\"",
    "start": "bun run --watch ./src/__lab__/index.ts"
  },
  "dependencies": {
    "dagre": "^0.8.5",
    "daily-code": "^1.1.16",
    "mermaid": "^11.12.2"
  },
  "peerDependencies": {
    "@xyflow/react": "^12",
    "quill": "*",
    "zod": "*"
  },
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@types/dagre": "^0.7.53",
    "@types/node": "^24.10.9",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "rolldown": "1.0.0-rc.2",
    "tsdown": "^0.15.12",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vitest": "^4.0.18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./headless": {
      "import": "./dist/headless.mjs",
      "require": "./dist/headless.cjs"
    },
    "./browser": {
      "import": "./dist/browser.mjs",
      "require": "./dist/browser.cjs"
    }
  },
  "typesVersions": {
    "*": {
      ".": [
        "./dist/index.d.mts",
        "./dist/index.d.cts"
      ],
      "headless": [
        "./dist/headless.d.mts",
        "./dist/headless.d.cts"
      ],
      "browser": [
        "./dist/browser.d.mts",
        "./dist/browser.d.cts"
      ]
    }
  }
}
